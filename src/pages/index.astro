---
/**
 * Recipe: Heritage Craft
 * Category: Roofing
 * Reference: Crocker Architectural (crockerarchitectural.com)
 * 
 * LUXURY / EDITORIAL recipe.
 * Cream + warm brown palette, Cormorant Garamond serif headings, editorial restraint.
 * Self-contained — NO external component imports.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../lib/site-config";
import { getSeoForPage } from "../lib/seo";

const seo = getSeoForPage("homepage");
const biz = siteConfig.business;
const content = siteConfig.content;
const homepage = content.homepage;
const services = content.services;
const serviceAreas = content.serviceAreas;
const reviews = content.reviews;
const info = content.companyInfo;
const images = siteConfig.images;

const displayServices = services.slice(0, 6);
const displayAreas = serviceAreas.slice(0, 8);
const displayReviews = reviews.slice(0, 3);
const galleryImages = images.gallery?.length ? images.gallery.slice(0, 6) : Object.values(images.services || {}).slice(0, 3);
const firstFaq = services[0]?.faq || [];

const heroImage = images.hero;
const phone = biz.phone || "";
const fax = biz.fax || "";
const email = biz.email || "";
const city = biz.city || "";
const state = biz.state || "";
const category = biz.category || "Roofing";
const bizName = biz.name || "";
const address = biz.address || "";
const zip = biz.zip || "";

const benefitsList = [
  { title: "Quality Craftsmanship", desc: "Every project completed to the highest standards of excellence" },
  { title: "Specialized Knowledge", desc: "Deep expertise in all roofing systems and materials" },
  { title: "State-of-the-Art Methods", desc: "Modern techniques that ensure lasting results" },
  { title: "Long-Term Durability", desc: "Solutions built to withstand the test of time" },
];

const whyChooseUs = [
  "Quality Craftsmanship",
  "Specialized Knowledge",
  "Comprehensive Services",
  "Proven Track Record",
  "Family-Owned Commitment",
];

const industries = [
  { name: "General Contractors", desc: "Trusted partner for commercial and residential builders" },
  { name: "Private Residences", desc: "Premium roofing solutions for discerning homeowners" },
  { name: "Commercial Properties", desc: "Durable systems for offices, retail, and industrial" },
  { name: "Municipal Buildings", desc: "Reliable service for government and public facilities" },
  { name: "Historic Preservation", desc: "Sensitive restoration of heritage structures" },
];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
>

  <!-- ═══════════════════════════════════════════════ NAV ═══════════════════════════════════════════════ -->
  <nav class="hc-nav">
    <div class="hc-nav-inner">
      <div class="hc-nav-left">
        <a href="/" class="hc-nav-link">Home</a>
        <div class="hc-nav-dropdown">
          <button class="hc-nav-link hc-nav-dropdown-trigger" aria-expanded="false" aria-haspopup="true">
            Capabilities <span class="hc-nav-arrow">▾</span>
          </button>
          <div class="hc-nav-dropdown-menu">
            <div class="hc-nav-dropdown-section">
              <span class="hc-nav-dropdown-label">Services</span>
              {services.map((s) => (
                <a href={`/services/${s.slug}/`} class="hc-nav-dropdown-item">{s.name}</a>
              ))}
            </div>
            <div class="hc-nav-dropdown-section">
              <span class="hc-nav-dropdown-label">Service Areas</span>
              {serviceAreas.map((a) => (
                <a href={`/service-areas/${a.slug}/`} class="hc-nav-dropdown-item">{a.name}</a>
              ))}
            </div>
          </div>
        </div>
        <a href="/gallery/" class="hc-nav-link">Gallery</a>
        <a href="/about/" class="hc-nav-link">About Us</a>
        <a href="/contact/" class="hc-nav-link">Contact Us</a>
      </div>
      <div class="hc-nav-center">
        <a href="/" class="hc-nav-brand">{bizName}</a>
      </div>
      <div class="hc-nav-right">
        {phone && (
          <a href={`tel:${phone.replace(/[^+\d]/g, "")}`} class="hc-nav-phone">{phone}</a>
        )}
        {fax && (
          <span class="hc-nav-fax">Fax: {fax}</span>
        )}
      </div>
      <button class="hc-mobile-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span class="hc-hamburger"></span>
      </button>
    </div>
    <!-- Mobile menu -->
    <div class="hc-mobile-menu">
      <a href="/" class="hc-mobile-link">Home</a>
      <div class="hc-mobile-accordion">
        <button class="hc-mobile-link hc-mobile-accordion-trigger">Capabilities <span class="hc-nav-arrow">▾</span></button>
        <div class="hc-mobile-accordion-content">
          <span class="hc-mobile-sublabel">Services</span>
          {services.map((s) => (
            <a href={`/services/${s.slug}/`} class="hc-mobile-sublink">{s.name}</a>
          ))}
          <span class="hc-mobile-sublabel">Service Areas</span>
          {serviceAreas.map((a) => (
            <a href={`/service-areas/${a.slug}/`} class="hc-mobile-sublink">{a.name}</a>
          ))}
        </div>
      </div>
      <a href="/gallery/" class="hc-mobile-link">Gallery</a>
      <a href="/about/" class="hc-mobile-link">About Us</a>
      <a href="/contact/" class="hc-mobile-link">Contact Us</a>
      {phone && (
        <a href={`tel:${phone.replace(/[^+\d]/g, "")}`} class="hc-mobile-phone">{phone}</a>
      )}
    </div>
  </nav>


  <!-- ═══════════════════════════════════════════════ HERO ═════════════════════════════════════════════ -->
  <section class="hc-hero">
    {heroImage && <img src={heroImage} alt={`${bizName} — ${category} in ${city}`} class="hc-hero-img" loading="eager" />}
    <div class="hc-hero-overlay"></div>
    <div class="hc-hero-content">
      <h1 class="hc-hero-heading">{city}'s Leader in<br />Professional {category}</h1>
      <div class="hc-hero-buttons">
        <a href="/gallery/" class="hc-btn-outline-white">Our Gallery &rarr;</a>
        <a href="/about/" class="hc-btn-outline-white">About Us &rarr;</a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════ INTRODUCTION ════════════════════════════════════ -->
  <section class="hc-intro">
    <div class="hc-container hc-intro-inner">
      <span class="hc-section-label">Welcome</span>
      <h2 class="hc-intro-heading">{bizName}</h2>
      <p class="hc-intro-text">
        {homepage.intro || `${bizName} has been serving ${city} and the surrounding region with premium ${category.toLowerCase()} services built on a foundation of integrity, craftsmanship, and an unwavering commitment to excellence. Our team brings decades of combined experience to every project, ensuring results that stand the test of time.`}
      </p>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════ WHY CHOOSE US ═══════════════════════════════════ -->
  <section class="hc-why">
    <div class="hc-container">
      <div class="hc-why-grid">
        <div class="hc-why-content">
          <span class="hc-section-label">Why Choose Us</span>
          <h2 class="hc-heading-lg">Why {city} Trusts {bizName}</h2>
          <ul class="hc-why-list">
            {whyChooseUs.map((item) => (
              <li class="hc-why-item">
                <span class="hc-bullet">&#10022;</span> {item}
              </li>
            ))}
          </ul>
          <a href="/contact/" class="hc-btn-brown">Work With Us &rarr;</a>
        </div>
        <div class="hc-why-side"></div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════ CERTIFICATIONS ══════════════════════════════════ -->
  <section class="hc-certs">
    <div class="hc-container">
      <span class="hc-section-label hc-text-center">Affiliations &amp; Certifications</span>
      <div class="hc-certs-row">
        <!-- NRCA-style Shield -->
        <div class="hc-cert-item" title="National Roofing Certification">
          <svg class="hc-cert-svg" viewBox="0 0 60 72" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M30 2L4 16V38C4 52.5 15.5 65 30 70C44.5 65 56 52.5 56 38V16L30 2Z" stroke="currentColor" stroke-width="2.5" fill="none"/>
            <text x="30" y="42" text-anchor="middle" font-size="18" font-weight="600" fill="currentColor">NR</text>
          </svg>
        </div>
        <!-- MCA Hammer -->
        <div class="hc-cert-item" title="Metal Construction Association">
          <svg class="hc-cert-svg" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="30" cy="30" r="28" stroke="currentColor" stroke-width="2.5" fill="none"/>
            <path d="M22 18H38V24H34V44H26V24H22V18Z" stroke="currentColor" stroke-width="2" fill="none"/>
          </svg>
        </div>
        <!-- ABC Triangle -->
        <div class="hc-cert-item" title="Associated Builders & Contractors">
          <svg class="hc-cert-svg" viewBox="0 0 64 60" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M32 4L4 56H60L32 4Z" stroke="currentColor" stroke-width="2.5" fill="none"/>
            <text x="32" y="44" text-anchor="middle" font-size="14" font-weight="600" fill="currentColor">ABC</text>
          </svg>
        </div>
        <!-- Star Badge -->
        <div class="hc-cert-item" title="Quality Certified">
          <svg class="hc-cert-svg" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="30" cy="30" r="28" stroke="currentColor" stroke-width="2.5" fill="none"/>
            <polygon points="30,10 35,24 50,24 38,33 42,47 30,38 18,47 22,33 10,24 25,24" stroke="currentColor" stroke-width="1.5" fill="none"/>
          </svg>
        </div>
        <!-- Wrench Badge -->
        <div class="hc-cert-item" title="Licensed Professional">
          <svg class="hc-cert-svg" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="4" y="4" width="52" height="52" rx="8" stroke="currentColor" stroke-width="2.5" fill="none"/>
            <path d="M20 40L36 24M38 18A6 6 0 0 0 28 28L18 38A3 3 0 0 0 22 42L32 32A6 6 0 0 0 42 22L38 26L34 22L38 18Z" stroke="currentColor" stroke-width="2" fill="none"/>
          </svg>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════ OUR SERVICES ════════════════════════════════════ -->
  <section class="hc-services">
    <div class="hc-container">
      <span class="hc-section-label hc-text-center">What We Do</span>
      <h2 class="hc-heading-lg hc-text-center">Our Services</h2>
      <div class="hc-services-grid">
        {displayServices.map((s) => {
          const sImg = images.services?.[s.slug] || null;
          return (
            <a href={`/services/${s.slug}/`} class="hc-service-card">
              <div class="hc-service-img-wrap">
                {sImg && <img src={sImg} alt={s.name} class="hc-service-img" loading="lazy" />}
                {!sImg && heroImage && <img src={heroImage} alt={s.name} class="hc-service-img" loading="lazy" />}
              </div>
              <div class="hc-service-body">
                <h3 class="hc-service-name">{s.name}</h3>
                <p class="hc-service-desc">{s.excerpt || s.description?.slice(0, 120) + "..." || ""}</p>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════ BENEFITS / DIFFERENTIATORS ══════════════════════ -->
  <section class="hc-benefits">
    <div class="hc-container">
      <div class="hc-benefits-grid">
        <div class="hc-benefits-content">
          <span class="hc-section-label">Our Difference</span>
          <h2 class="hc-heading-lg">The Benefits of Choosing {bizName}</h2>
          <ul class="hc-benefits-list">
            {benefitsList.map((b) => (
              <li class="hc-benefit-item">
                <span class="hc-bullet">&#10022;</span>
                <div>
                  <strong>{b.title}</strong>
                  <p class="hc-benefit-desc">{b.desc}</p>
                </div>
              </li>
            ))}
          </ul>
          <a href="/contact/" class="hc-btn-brown">Contact Us &rarr;</a>
        </div>
        <div class="hc-benefits-image">
          {galleryImages[0] && <img src={galleryImages[0]} alt={`${bizName} project`} class="hc-benefits-img" loading="lazy" />}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════ TESTIMONIAL ═════════════════════════════════════ -->
  {displayReviews.length > 0 && (
    <section class="hc-testimonial">
      <div class="hc-container hc-testimonial-inner">
        <span class="hc-quote-mark">&ldquo;</span>
        <blockquote class="hc-quote-text">
          {displayReviews[0].text || displayReviews[0].body || displayReviews[0].content || "An exceptional experience from start to finish. The professionalism, attention to detail, and quality of work exceeded all expectations."}
        </blockquote>
        <cite class="hc-quote-cite">
          &mdash; {displayReviews[0].author || displayReviews[0].name || "Satisfied Client"}
          {(displayReviews[0].title || displayReviews[0].company) && (
            <span class="hc-quote-title">, {displayReviews[0].title || displayReviews[0].company}</span>
          )}
        </cite>
      </div>
    </section>
  )}


  <!-- ═══════════════════════════════════════════════ INDUSTRIES / CLIENTS SERVED ═════════════════════ -->
  <section class="hc-industries">
    <div class="hc-container">
      <span class="hc-section-label hc-text-center">Who We Serve</span>
      <h2 class="hc-heading-lg hc-text-center">Industries &amp; Clients We Serve</h2>
      <div class="hc-industries-grid">
        {industries.map((ind) => (
          <div class="hc-industry-item">
            <h3 class="hc-industry-name">{ind.name}</h3>
            <p class="hc-industry-desc">{ind.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════ CTA ═════════════════════════════════════════════ -->
  <section class="hc-cta">
    <div class="hc-container hc-cta-inner">
      <span class="hc-section-label hc-text-center">Get Started</span>
      <h2 class="hc-heading-lg hc-text-center">Ready to Start Your Project?</h2>
      <p class="hc-cta-text">
        Whether you need a complete roof replacement, expert repairs, or a consultation on your next project,
        our team is ready to deliver the quality and professionalism you deserve.
      </p>
      <p class="hc-cta-talk">Let's Talk</p>
      {phone && (
        <a href={`tel:${phone.replace(/[^+\d]/g, "")}`} class="hc-cta-phone">{phone}</a>
      )}
      <a href="/contact/" class="hc-btn-brown">Get in Touch &rarr;</a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════ FOOTER ══════════════════════════════════════════ -->
  <footer class="hc-footer">
    <div class="hc-footer-accent"></div>
    <div class="hc-container">
      <div class="hc-footer-grid">
        <!-- Column 1: About -->
        <div class="hc-footer-col">
          <h4 class="hc-footer-heading">About Us</h4>
          <p class="hc-footer-text">
            {info?.shortDescription || `${bizName} provides premium ${category.toLowerCase()} services to ${city}, ${state} and surrounding communities. Quality, integrity, and craftsmanship define everything we do.`}
          </p>
          <p class="hc-footer-address">
            {address && <span>{address}<br /></span>}
            {city && <span>{city}, {state} {zip}</span>}
          </p>
        </div>
        <!-- Column 2: Contact -->
        <div class="hc-footer-col">
          <h4 class="hc-footer-heading">Contact</h4>
          {phone && (
            <p class="hc-footer-contact-item">
              <span class="hc-footer-contact-label">Phone:</span>
              <a href={`tel:${phone.replace(/[^+\d]/g, "")}`} class="hc-footer-link">{phone}</a>
            </p>
          )}
          {email && (
            <p class="hc-footer-contact-item">
              <span class="hc-footer-contact-label">Email:</span>
              <a href={`mailto:${email}`} class="hc-footer-link">{email}</a>
            </p>
          )}
          {fax && (
            <p class="hc-footer-contact-item">
              <span class="hc-footer-contact-label">Fax:</span>
              <span>{fax}</span>
            </p>
          )}
        </div>
        <!-- Column 3: Quick Links -->
        <div class="hc-footer-col">
          <h4 class="hc-footer-heading">Quick Links</h4>
          <ul class="hc-footer-links">
            <li><a href="/" class="hc-footer-link">Home</a></li>
            {displayServices.slice(0, 4).map((s) => (
              <li><a href={`/services/${s.slug}/`} class="hc-footer-link">{s.name}</a></li>
            ))}
            <li><a href="/gallery/" class="hc-footer-link">Gallery</a></li>
            <li><a href="/about/" class="hc-footer-link">About Us</a></li>
            <li><a href="/contact/" class="hc-footer-link">Contact Us</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="hc-footer-bottom">
      <div class="hc-container">
        <p class="hc-copyright">&copy; {new Date().getFullYear()} {bizName}. All rights reserved.</p>
      </div>
    </div>
  </footer>


  <!-- ═══════════════════════════════════════════════ NAV SCRIPT ══════════════════════════════════════ -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Mobile toggle
      const toggle = document.querySelector(".hc-mobile-toggle");
      const menu = document.querySelector(".hc-mobile-menu");
      if (toggle && menu) {
        toggle.addEventListener("click", () => {
          const expanded = toggle.getAttribute("aria-expanded") === "true";
          toggle.setAttribute("aria-expanded", String(!expanded));
          menu.classList.toggle("hc-mobile-menu--open");
          toggle.classList.toggle("hc-mobile-toggle--open");
        });
      }
      // Mobile accordions
      document.querySelectorAll(".hc-mobile-accordion-trigger").forEach((btn) => {
        btn.addEventListener("click", () => {
          const content = btn.nextElementSibling;
          if (content) content.classList.toggle("hc-mobile-accordion-content--open");
          btn.classList.toggle("hc-mobile-accordion-trigger--open");
        });
      });
      // Desktop dropdown hover (keep for keyboard too)
      document.querySelectorAll(".hc-nav-dropdown").forEach((dd) => {
        const trigger = dd.querySelector(".hc-nav-dropdown-trigger");
        const menuEl = dd.querySelector(".hc-nav-dropdown-menu");
        if (!trigger || !menuEl) return;
        let timeout;
        const show = () => { clearTimeout(timeout); menuEl.classList.add("hc-nav-dropdown-menu--open"); trigger.setAttribute("aria-expanded", "true"); };
        const hide = () => { timeout = setTimeout(() => { menuEl.classList.remove("hc-nav-dropdown-menu--open"); trigger.setAttribute("aria-expanded", "false"); }, 200); };
        dd.addEventListener("mouseenter", show);
        dd.addEventListener("mouseleave", hide);
        trigger.addEventListener("click", (e) => { e.preventDefault(); menuEl.classList.contains("hc-nav-dropdown-menu--open") ? hide() : show(); });
      });
    });
  </script>

</BaseLayout>


<!-- ═══════════════════════════════════════════════════════════════════════════════════════════════════ -->
<!-- ═══════════════════════════════════════ STYLES ═══════════════════════════════════════════════════ -->
<!-- ═══════════════════════════════════════════════════════════════════════════════════════════════════ -->
<style>
  /* ─── VARIABLES ─── */
  :root {
    --hc-cream: #F5F5F0;
    --hc-white: #FFFFFF;
    --hc-brown: #8B7355;
    --hc-dark: #2A2A2A;
    --hc-text-light: #6B6B6B;
    --hc-border: #DDD5C8;
    --hc-accent: #A0522D;
  }

  /* ─── GLOBAL RESET ─── */
  * { margin: 0; padding: 0; box-sizing: border-box; }

  .hc-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hc-text-center { text-align: center; }

  .hc-section-label {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.8rem;
    color: var(--hc-brown);
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .hc-heading-lg {
    font-family: 'Cormorant Garamond', 'Garamond', serif;
    font-weight: 600;
    font-size: 2.4rem;
    color: var(--hc-dark);
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .hc-bullet {
    color: var(--hc-brown);
    margin-right: 0.5rem;
    font-size: 0.9rem;
  }


  /* ─── BUTTONS ─── */
  .hc-btn-brown {
    display: inline-block;
    border: 2px solid var(--hc-brown);
    color: var(--hc-brown);
    padding: 0.75rem 2rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.85rem;
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.3s, color 0.3s;
    background: transparent;
  }
  .hc-btn-brown:hover {
    background: var(--hc-brown);
    color: var(--hc-white);
  }

  .hc-btn-outline-white {
    display: inline-block;
    border: 2px solid rgba(255,255,255,0.8);
    color: var(--hc-white);
    padding: 0.75rem 2rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.85rem;
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.3s, color 0.3s;
    background: transparent;
  }
  .hc-btn-outline-white:hover {
    background: rgba(255,255,255,0.15);
    border-color: var(--hc-white);
  }


  /* ═══════ NAV ═══════ */
  .hc-nav {
    background: var(--hc-brown);
    position: sticky;
    top: 0;
    z-index: 1000;
  }
  .hc-nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .hc-nav-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .hc-nav-link {
    color: var(--hc-white);
    text-decoration: none;
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.2s;
  }
  .hc-nav-link:hover { opacity: 0.8; }
  .hc-nav-arrow { font-size: 0.65rem; margin-left: 0.2rem; }
  .hc-nav-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .hc-nav-brand {
    color: var(--hc-white);
    text-decoration: none;
    font-family: 'Cormorant Garamond', 'Garamond', serif;
    font-weight: 600;
    font-size: 1.35rem;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .hc-nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .hc-nav-phone {
    color: var(--hc-white);
